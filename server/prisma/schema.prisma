generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  profileImage  String?
  provider      Provider
  providerId    String
  role          Role      @default(CUSTOMER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  password      String?
  chatLogs      ChatLog[]
  giftsSent     Gift[]    @relation("GiftsSent")
  giftsReceived Gift[]    @relation("GiftsReceived")
  orders        Order[]
  reviews       Review[]
  weddings      Wedding[]
  pairWeddings  Wedding[] @relation("PairWeddings")

  @@unique([provider, providerId])
}

model Package {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  price        Int
  description  String
  features     String[]
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  maxEdits     Int      @default(-1)
  durationDays Int      @default(365)
  gifts        Gift[]
  orders       Order[]
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  packageId  String
  amount     Int
  status     OrderStatus @default(PENDING)
  paymentKey String?
  couponCode String?
  orderId    String      @unique
  paidAt     DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  package    Package     @relation(fields: [packageId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  wedding    Wedding?
}

model ChatLog {
  id        String   @id @default(cuid())
  userId    String?
  visitorId String?
  role      ChatRole
  content   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Wedding {
  id                       String            @id @default(cuid())
  userId                   String
  pairUserId               String?
  orderId                  String?           @unique
  slug                     String            @unique
  theme                    Theme             @default(ROMANTIC_CLASSIC)
  isPublished              Boolean           @default(false)
  isArchived               Boolean           @default(false)
  weddingDate              DateTime
  weddingTime              String
  groomName                String
  groomNameEn              String?
  groomPhone               String?
  groomFatherName          String?
  groomMotherName          String?
  groomFatherPhone         String?
  groomMotherPhone         String?
  brideName                String
  brideNameEn              String?
  bridePhone               String?
  brideFatherName          String?
  brideMotherName          String?
  brideFatherPhone         String?
  brideMotherPhone         String?
  showParents              Boolean           @default(true)
  greeting                 String?
  greetingTitle            String?
  loveStory                String?
  loveStoryType            StoryType         @default(PHOTO)
  loveStoryVideo           String?
  usePhotoFilter           Boolean           @default(true)
  venue                    String
  venueHall                String?
  venueAddress             String
  venuePhone               String?
  venueMapUrl              String?
  venueNaverMap            String?
  venueKakaoMap            String?
  transportInfo            String?
  parkingInfo              String?
  venueTmap                String?
  venueLatitude            Float?
  venueLongitude           Float?
  groomAccount             String?
  groomBank                String?
  groomAccountHolder       String?
  brideAccount             String?
  brideBank                String?
  brideAccountHolder       String?
  groomFatherAccount       String?
  groomFatherBank          String?
  groomFatherAccountHolder String?
  groomMotherAccount       String?
  groomMotherBank          String?
  groomMotherAccountHolder String?
  brideFatherAccount       String?
  brideFatherBank          String?
  brideFatherAccountHolder String?
  brideMotherAccount       String?
  brideMotherBank          String?
  brideMotherAccountHolder String?
  tossLink                 String?
  kakaoPayLink             String?
  closingMessage           String?
  bgMusicUrl               String?
  bgMusicAutoPlay          Boolean           @default(false)
  showDday                 Boolean           @default(true)
  heroMedia                String?
  heroMediaType            MediaType         @default(IMAGE)
  mainColor                String?
  accentColor              String?
  fontFamily               String?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  textColor                String?
  themeColor               String?           @default("#1E3A5F")
  aiBridePersonality       String?
  aiCustomQna              Json?
  aiEnabled                Boolean           @default(false)
  aiGroomPersonality       String?
  aiMenuInfo               Json?
  aiSecrets                Json?
  aiTransportInfo          Json?
  aiName                   String?
  aiMode                   String?           @default("classic")
  editCount                Int               @default(0)
  aiToneStyle              String?           @default("default")
  notificationEnabled      Boolean           @default(true)
  reminderD1               Boolean           @default(true)
  reminderD3               Boolean           @default(true)
  reminderD7               Boolean           @default(true)
  rsvpNotification         Boolean           @default(true)
  giftNotification         Boolean           @default(true)
  reminderSentDays         String?
  reportSentAt             DateTime?
  expiresAt                DateTime?
  sectionOrder             Json?
  aiChats                  AiChat[]
  galleries                Gallery[]
  guestbooks               Guestbook[]
  reportTokens             ReportToken[]
  reviews                  Review[]
  rsvps                    Rsvp[]
  order                    Order?            @relation(fields: [orderId], references: [id])
  user                     User              @relation(fields: [userId], references: [id])
  pairUser                 User?             @relation("PairWeddings", fields: [pairUserId], references: [id])
  pairInvites              PairInvite[]
  snapshots                WeddingSnapshot[]
}

model WeddingSnapshot {
  id        String   @id @default(cuid())
  weddingId String
  version   String   @unique
  data      Json
  sharedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model AiChat {
  id        String   @id @default(cuid())
  weddingId String
  visitorId String
  role      ChatRole
  content   String
  createdAt DateTime @default(now())
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Gallery {
  id        String    @id @default(cuid())
  weddingId String
  mediaUrl  String
  mediaType MediaType @default(IMAGE)
  order     Int       @default(0)
  caption   String?
  createdAt DateTime  @default(now())
  wedding   Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Rsvp {
  id         String   @id @default(cuid())
  weddingId  String
  name       String
  phone      String?
  side       Side     @default(GROOM)
  attending  Boolean
  guestCount Int      @default(1)
  mealCount  Int      @default(0)
  message    String?
  createdAt  DateTime @default(now())
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Guestbook {
  id        String   @id @default(cuid())
  weddingId String
  name      String
  password  String
  message   String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  type      String        @default("general")
  message   String
  status    InquiryStatus @default(PENDING)
  reply     String?
  repliedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  content   String
  updatedAt DateTime @updatedAt
}

model ReportToken {
  id        String   @id @default(cuid())
  weddingId String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  weddingId String
  rating    Int
  content   String?
  createdAt DateTime @default(now())
  isPublic  Boolean  @default(false)
  source    String   @default("GENERAL")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Gift {
  id         String    @id @default(cuid())
  code       String    @unique
  packageId  String
  fromUserId String?
  toEmail    String?
  toPhone    String?
  toUserId   String?
  message    String?
  isRedeemed Boolean   @default(false)
  redeemedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  fromUser   User?     @relation("GiftsSent", fields: [fromUserId], references: [id])
  package    Package   @relation(fields: [packageId], references: [id])
  toUser     User?     @relation("GiftsReceived", fields: [toUserId], references: [id])
}

model Guide {
  id          String   @id @default(cuid())
  title       String
  description String?
  videoUrl    String
  videoType   String   @default("UPLOAD")
  category    String   @default("GENERAL")
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ThemeShowcase {
  id          String   @id @default(cuid())
  theme       Theme
  title       String
  description String?
  sampleData  Json?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Provider {
  KAKAO
  GOOGLE
  EMAIL
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum ChatRole {
  USER
  ASSISTANT
}

enum Theme {
  ROMANTIC_CLASSIC
  MODERN_MINIMAL
  BOHEMIAN_DREAM
  LUXURY_GOLD
  POETIC_LOVE
  SENIOR_SIMPLE
  FOREST_GARDEN
  OCEAN_BREEZE
  GLASS_BUBBLE
  SPRING_BREEZE
  GALLERY_MIRIM_1
  GALLERY_MIRIM_2
  LUNA_HALFMOON
  PEARL_DRIFT
  NIGHT_SEA
  AQUA_GLOBE
  BOTANICAL_CLASSIC
  HEART_MINIMAL
  WAVE_BORDER
}

enum MediaType {
  IMAGE
  VIDEO
}

enum StoryType {
  PHOTO
  VIDEO
}

enum Side {
  GROOM
  BRIDE
}

enum InquiryStatus {
  PENDING
  REPLIED
  CLOSED
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  discountType  String    @default("PERCENT")
  discountValue Int
  maxUses       Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PairInvite {
  id         String           @id @default(cuid())
  weddingId  String
  code       String           @unique
  invitedBy  String
  status     PairInviteStatus @default(PENDING)
  expiresAt  DateTime
  acceptedBy String?
  createdAt  DateTime         @default(now())
  wedding    Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

enum PairInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model HighlightVideo {
  id           String   @id @default(cuid())
  title        String
  description  String?
  videoUrl     String
  thumbnailUrl String?
  duration     String?
  order        Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
