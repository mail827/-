generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  profileImage  String?
  provider      Provider
  providerId    String
  role          Role      @default(CUSTOMER)
  freeSnapUsed  Boolean   @default(false)
  snapPacks     SnapPack[]
  aiSnaps       AiSnap[]
  snapGiftsSent     SnapGift[] @relation("SnapGiftsSent")
  snapGiftsReceived SnapGift[] @relation("SnapGiftsReceived")
  videoGiftsSent     VideoGift[] @relation("VideoGiftsSent")
  videoGiftsReceived VideoGift[] @relation("VideoGiftsReceived")
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  password      String?
  chatLogs      ChatLog[]
  giftsSent     Gift[]    @relation("GiftsSent")
  giftsReceived Gift[]    @relation("GiftsReceived")
  orders        Order[]
  reviews       Review[]
  preweddingVideos PreweddingVideo[]
  weddings      Wedding[]
  pairWeddings  Wedding[] @relation("PairWeddings")

  @@unique([provider, providerId])
}

model Package {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  price        Int
  description  String
  features     String[]
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  maxEdits     Int      @default(-1)
  durationDays Int      @default(365)
  gifts        Gift[]
  orders       Order[]
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  packageId  String
  amount     Int
  status     OrderStatus @default(PENDING)
  paymentKey String?
  couponCode String?
  orderId    String      @unique
  paidAt     DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  package    Package     @relation(fields: [packageId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  wedding    Wedding?
}

model ChatLog {
  id        String   @id @default(cuid())
  userId    String?
  visitorId String?
  role      ChatRole
  content   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Wedding {
  id                       String            @id @default(cuid())
  userId                   String
  pairUserId               String?
  orderId                  String?           @unique
  slug                     String            @unique
  theme                    Theme             @default(ROMANTIC_CLASSIC)
  locale                   String            @default("ko")
  showLocaleSwitch         Boolean           @default(true)
  translationsEn           Json?
  isPublished              Boolean           @default(false)
  isArchived               Boolean           @default(false)
  weddingDate              DateTime
  weddingTime              String
  groomName                String
  groomNameEn              String?
  groomPhone               String?
  groomFatherName          String?
  groomMotherName          String?
  groomFatherPhone         String?
  groomMotherPhone         String?
  brideName                String
  brideNameEn              String?
  bridePhone               String?
  brideFatherName          String?
  brideMotherName          String?
  brideFatherPhone         String?
  brideMotherPhone         String?
  showParents              Boolean           @default(true)
  greeting                 String?
  greetingTitle            String?
  loveStory                String?
  loveStoryType            StoryType         @default(PHOTO)
  loveStoryVideo           String?
  usePhotoFilter           Boolean           @default(true)
  venue                    String
  venueHall                String?
  venueAddress             String
  mealText                 String?
  venuePhone               String?
  venueMapUrl              String?
  venueNaverMap            String?
  venueKakaoMap            String?
  transportInfo            String?
  parkingInfo              String?
  venueTmap                String?
  venueLatitude            Float?
  venueLongitude           Float?
  groomAccount             String?
  groomBank                String?
  groomAccountHolder       String?
  brideAccount             String?
  brideBank                String?
  brideAccountHolder       String?
  groomFatherAccount       String?
  groomFatherBank          String?
  groomFatherAccountHolder String?
  groomMotherAccount       String?
  groomMotherBank          String?
  groomMotherAccountHolder String?
  brideFatherAccount       String?
  brideFatherBank          String?
  brideFatherAccountHolder String?
  brideMotherAccount       String?
  brideMotherBank          String?
  brideMotherAccountHolder String?
  tossLink                 String?
  kakaoPayLink             String?
  closingMessage           String?
  bgMusicUrl               String?
  bgMusicAutoPlay          Boolean           @default(false)
  showDday                 Boolean           @default(true)
  heroMedia                String?
  heroMediaType            MediaType         @default(IMAGE)
  heroImagePosition        String?           @default("50% 50%")
  mainColor                String?
  accentColor              String?
  fontScale                String?          @default("medium")
  fontFamily               String?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  textColor                String?
  themeColor               String?           @default("#1E3A5F")
  aiBridePersonality       String?
  aiCustomQna              Json?
  aiEnabled                Boolean           @default(false)
  aiGroomPersonality       String?
  aiMenuInfo               Json?
  aiSecrets                Json?
  aiTransportInfo          Json?
  aiName                   String?
  aiMode                   String?           @default("classic")
  editCount                Int               @default(0)
  aiToneStyle              String?           @default("default")
  notificationEnabled      Boolean           @default(true)
  reminderD1               Boolean           @default(true)
  reminderD3               Boolean           @default(true)
  reminderD7               Boolean           @default(true)
  rsvpNotification         Boolean           @default(true)
  giftNotification         Boolean           @default(true)
  reminderSentDays         String?
  reportSentAt             DateTime?
  expiresAt                DateTime?
  sectionOrder             Json?
  hiddenSections           Json?
  galleryRatio             String?          @default("1:1")
  aiBoothEnabled           Boolean          @default(false)
  boothCredits             Int              @default(10)
  guestPhotoEnabled        Boolean          @default(true)
  galleryLayout        String?          @default("grid")
  groomIntro           String?
  brideIntro           String?
  groomProfileUrl      String?
  brideProfileUrl      String?
  showProfile          Boolean          @default(false)
  venueDetailTabs      Json?
  ogCoverType          String?          @default("default")
  ogCustomTitle        String?
  ogCustomImage        String?
  groomLetter        String?
  brideLetter        String?
  groomLetterImage   String?
  brideLetterImage   String?
  showLetter         Boolean          @default(false)
  letterFromVisible  Boolean          @default(true)
  heroTextPosition       String?          @default("50")
  heroNamePosition       String?          @default("85")
  heroScriptFont         String?
  heroLayout             String?          @default("spread")
  envelopeEnabled      Boolean          @default(false)
  envelopeStyle        String?          @default("ivory")
  envelopeCardStyle    String?          @default("white_crumple")
  envelopeCardText     String?
  envelopeCardColor    String?
  aiChats                  AiChat[]
  galleries                Gallery[]
  aiSnaps                  AiSnap[]
  guestbooks               Guestbook[]
  reportTokens             ReportToken[]
  reviews                  Review[]
  rsvps                    Rsvp[]
  order                    Order?            @relation(fields: [orderId], references: [id])
  user                     User              @relation(fields: [userId], references: [id])
  pairUser                 User?             @relation("PairWeddings", fields: [pairUserId], references: [id])
  pairInvites              PairInvite[]
  snapshots                WeddingSnapshot[]
  guestPhotos              GuestPhoto[]
  boothCreditOrders        BoothCreditOrder[]
  preweddingVideos         PreweddingVideo[]
}

model WeddingSnapshot {
  id        String   @id @default(cuid())
  weddingId String
  version   String   @unique
  label     String?
  viewCount Int      @default(0)
  data      Json
  sharedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model AiChat {
  id        String   @id @default(cuid())
  weddingId String
  visitorId String
  role      ChatRole
  content   String
  createdAt DateTime @default(now())
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Gallery {
  id        String    @id @default(cuid())
  weddingId String
  mediaUrl  String
  mediaType MediaType @default(IMAGE)
  order     Int       @default(0)
  caption   String?
  createdAt DateTime  @default(now())
  wedding   Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model GuestPhoto {
  id         String   @id @default(cuid())
  weddingId  String
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guestName  String   @default("익명")
  imageUrl   String
  mediaType  String   @default("IMAGE")
  publicId   String?
  message    String?
  approved   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Rsvp {
  id         String   @id @default(cuid())
  weddingId  String
  name       String
  phone      String?
  side       Side     @default(GROOM)
  attending  Boolean
  guestCount Int      @default(1)
  mealCount  Int      @default(0)
  message    String?
  createdAt  DateTime @default(now())
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Guestbook {
  id        String   @id @default(cuid())
  weddingId String
  name      String
  password  String
  message   String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  type      String        @default("general")
  message   String
  status    InquiryStatus @default(PENDING)
  reply     String?
  repliedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  content   String
  updatedAt DateTime @updatedAt
}

model ReportToken {
  id        String   @id @default(cuid())
  weddingId String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  weddingId String
  rating    Int
  content   String?
  createdAt DateTime @default(now())
  isPublic  Boolean  @default(false)
  source    String   @default("GENERAL")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Gift {
  id         String    @id @default(cuid())
  code       String    @unique
  packageId  String
  fromUserId String?
  toEmail    String?
  toPhone    String?
  toUserId   String?
  message    String?
  isRedeemed Boolean   @default(false)
  redeemedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  fromUser   User?     @relation("GiftsSent", fields: [fromUserId], references: [id])
  package    Package   @relation(fields: [packageId], references: [id])
  toUser     User?     @relation("GiftsReceived", fields: [toUserId], references: [id])
}

model Guide {
  id          String   @id @default(cuid())
  title       String
  description String?
  videoUrl    String
  videoType   String   @default("UPLOAD")
  category    String   @default("GENERAL")
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ThemeShowcase {
  id          String   @id @default(cuid())
  theme       Theme
  title       String
  description String?
  sampleData  Json?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Provider {
  KAKAO
  GOOGLE
  EMAIL
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum ChatRole {
  USER
  ASSISTANT
}

enum Theme {
  ROMANTIC_CLASSIC
  MODERN_MINIMAL
  BOHEMIAN_DREAM
  LUXURY_GOLD
  POETIC_LOVE
  SENIOR_SIMPLE
  FOREST_GARDEN
  OCEAN_BREEZE
  GLASS_BUBBLE
  SPRING_BREEZE
  GALLERY_MIRIM_1
  GALLERY_MIRIM_2
  LUNA_HALFMOON
  PEARL_DRIFT
  NIGHT_SEA
  AQUA_GLOBE
  BOTANICAL_CLASSIC
  HEART_MINIMAL
  WAVE_BORDER
  CRUISE_DAY
  CRUISE_SUNSET
  VOYAGE_BLUE
  EDITORIAL
  EDITORIAL_WHITE
  EDITORIAL_GREEN
  EDITORIAL_BLUE
  EDITORIAL_BROWN
}

enum MediaType {
  IMAGE
  VIDEO
}

enum StoryType {
  PHOTO
  VIDEO
}

enum Side {
  GROOM
  BRIDE
}

enum InquiryStatus {
  PENDING
  REPLIED
  CLOSED
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  discountType  String    @default("PERCENT")
  discountValue Int
  maxUses       Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  category      String    @default("ALL")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PairInvite {
  id         String           @id @default(cuid())
  weddingId  String
  code       String           @unique
  invitedBy  String
  status     PairInviteStatus @default(PENDING)
  expiresAt  DateTime
  acceptedBy String?
  createdAt  DateTime         @default(now())
  wedding    Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

enum PairInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model HighlightVideo {
  id           String   @id @default(cuid())
  title        String
  description  String?
  videoUrl     String
  thumbnailUrl String?
  duration     String?
  order        Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model BgMusic {
  id        String   @id @default(cuid())
  title     String
  artist    String   @default("")
  category  String   @default("romantic")
  url       String
  duration  Int      @default(0)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model SnapGift {
  id         String    @id @default(cuid())
  code       String    @unique
  tier       String
  fromUserId String?
  fromUser   User?     @relation("SnapGiftsSent", fields: [fromUserId], references: [id])
  toEmail    String?
  toPhone    String?
  toUserId   String?
  toUser     User?     @relation("SnapGiftsReceived", fields: [toUserId], references: [id])
  message    String?
  isFree     Boolean   @default(false)
  isRedeemed Boolean   @default(false)
  redeemedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
}

model SnapPack {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  tier        String
  totalSnaps  Int
  usedSnaps   Int       @default(0)
  concept     String
  category    String    @default("studio")
  mode        String    @default("groom")
  inputUrls   Json      @default("[]")
  amount      Int
  couponCode    String?
  chainRefUrls  Json      @default("{}")
  preferredEngine String?
  status      String    @default("PENDING")
  paymentKey  String?
  orderId     String    @unique
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  snaps       AiSnap[]
}

model AiSnap {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  weddingId   String?
  wedding     Wedding?  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  snapPackId  String?
  snapPack    SnapPack? @relation(fields: [snapPackId], references: [id], onDelete: Cascade)
  concept     String
  mode        String?
  engine      String    @default("nano-banana")
  prompt      String
  inputUrls   Json
  resultUrl   String?
  resultOriginalUrl String?
  status      String    @default("pending")
  isFree      Boolean   @default(false)
  errorMsg    String?
  statusUrl   String?
  responseUrl String?
  retryResultUrl String?
  retryStatus    String?
  createdAt   DateTime  @default(now())
}

model AiSnapSample {
  id        String   @id @default(cuid())
  concept   String
  mode      String   @default("couple")
  imageUrl  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([concept])
}


model BoothCreditOrder {
  id         String   @id @default(cuid())
  weddingId  String
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  userId     String
  tier       String
  credits    Int
  amount     Int
  orderId    String   @unique
  paymentKey String?
  status     String   @default("PENDING")
  paidAt     DateTime?
  createdAt  DateTime @default(now())
}

model PreweddingVideo {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  weddingId     String?
  wedding       Wedding? @relation(fields: [weddingId], references: [id])
  status        String   @default("PENDING")
  templateId    String   @default("classic_film")
  mode          String   @default("photo")
  groomName     String
  brideName     String
  weddingDate   String?
  metStory      String?
  photos        Json     @default("[]")
  photoAnalysis Json?
  scenes        Json?
  bgmId         String?
  bgmUrl        String?
  fontId        String   @default("BMJUA_ttf")
  subtitleStyle String   @default("poetic")
  venueName     String   @default("")
  groomFather   String   @default("")
  groomMother   String   @default("")
  brideFather   String   @default("")
  brideMother   String   @default("")
  endingMessage  String   @default("")
  familyMembers  String   @default("")
  friendsList    String   @default("")
  specialThanks  String   @default("")
  creditTextColor String  @default("#ffffff")
  glamourResults  Json?
  subtitles     Json?
  clipUrls      Json?
  outputUrl     String?
  resolution    String   @default("1080p")
  aspectRatio   String   @default("9:16")
  totalDuration Float?
  totalCost     Float?
  couponCode    String?
  amount        Int
  orderId       String   @unique
  paymentKey    String?
  paidAt        DateTime?
  errorMsg      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([orderId])
}

model VideoGift {
  id         String    @id @default(cuid())
  code       String    @unique
  tier       String
  fromUserId String?
  fromUser   User?     @relation("VideoGiftsSent", fields: [fromUserId], references: [id])
  toEmail    String?
  toPhone    String?
  toUserId   String?
  toUser     User?     @relation("VideoGiftsReceived", fields: [toUserId], references: [id])
  message    String?
  isFree     Boolean   @default(false)
  isRedeemed Boolean   @default(false)
  redeemedAt DateTime?
  expiresAt  DateTime
  paymentKey String?
  orderId    String?   @unique
  amount     Int       @default(0)
  createdAt  DateTime  @default(now())
}

model Visit {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  device    String?
  browser   String?
  sessionId String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([utmSource])
  @@index([referrer])
}

model TeamTask {
  id        String   @id @default(cuid())
  weekId    String
  assignee  String
  category  String
  title     String
  target    Int?
  done      Int      @default(0)
  checked   Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weekId])
  @@index([assignee])
}

model TeamLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String   @default("")
  date      String
  content   String
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
}

model TeamNotice {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
}

model TeamFocus {
  id        String   @id @default(cuid())
  weekId    String
  priority  Int      @default(0)
  title     String
  assignee  String
  deadline  String?
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weekId])
}

model TeamMetric {
  id        String   @id @default(cuid())
  month     String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, key])
}

model TeamReview {
  id        String   @id @default(cuid())
  month     String
  field     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, field])
}

model TeamExpense {
  id        String   @id @default(cuid())
  date      String
  title     String
  category  String
  amount    Int
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([category])
}
