generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  profileImage  String?
  provider      Provider
  providerId    String
  role          Role      @default(CUSTOMER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  weddings      Wedding[]
  chatLogs      ChatLog[]
  giftsSent     Gift[]    @relation("GiftsSent")
  giftsReceived Gift[]    @relation("GiftsReceived")

  @@unique([provider, providerId])
}

model Package {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  price       Int
  description String
  features    String[]
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  maxEdits    Int      @default(-1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
  gifts       Gift[]
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  packageId     String
  package       Package     @relation(fields: [packageId], references: [id])
  amount        Int
  status        OrderStatus @default(PENDING)
  paymentKey    String?
  orderId       String      @unique
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  wedding       Wedding?
}

model ChatLog {
  id        String   @id @default(cuid())
  userId    String?
  visitorId String?
  user      User?    @relation(fields: [userId], references: [id])
  role      ChatRole
  content   String
  createdAt DateTime @default(now())
}

model Wedding {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  orderId         String?  @unique
  order           Order?   @relation(fields: [orderId], references: [id])
  slug            String   @unique
  theme           Theme    @default(ROMANTIC_CLASSIC)
  themeColor      String?  @default("#1E3A5F")
  isPublished     Boolean  @default(false)
  isArchived      Boolean  @default(false)
  editCount       Int      @default(0)
  weddingDate     DateTime
  weddingTime     String
  groomName       String
  groomNameEn     String?
  groomPhone      String?
  groomFatherName String?
  groomMotherName String?
  groomFatherPhone String?
  groomMotherPhone String?
  brideName       String
  brideNameEn     String?
  bridePhone      String?
  notificationEnabled Boolean @default(true)
  brideFatherName String?
  brideMotherName String?
  brideFatherPhone String?
  brideMotherPhone String?
  showParents     Boolean  @default(true)
  greeting        String?
  greetingTitle   String?
  loveStory       String?
  loveStoryType   StoryType @default(PHOTO)
  loveStoryVideo  String?
  venue           String
  venueHall       String?
  venueAddress    String
  venuePhone      String?
  venueMapUrl     String?
  venueNaverMap   String?
  venueKakaoMap   String?
  venueTmap       String?
  venueLatitude   Float?
  venueLongitude  Float?
  groomAccount    String?
  groomBank       String?
  groomAccountHolder String?
  brideAccount    String?
  brideBank       String?
  brideAccountHolder String?
  groomFatherAccount String?
  groomFatherBank String?
  groomFatherAccountHolder String?
  groomMotherAccount String?
  groomMotherBank String?
  groomMotherAccountHolder String?
  brideFatherAccount String?
  brideFatherBank String?
  brideFatherAccountHolder String?
  brideMotherAccount String?
  brideMotherBank String?
  brideMotherAccountHolder String?
  tossLink        String?
  kakaoPayLink    String?
  closingMessage  String?
  bgMusicUrl      String?
  bgMusicAutoPlay Boolean  @default(false)
  showDday        Boolean  @default(true)
  heroMedia       String?
  heroMediaType   MediaType @default(IMAGE)
  mainColor       String?
  accentColor     String?
  fontFamily      String?
  textColor       String?
  
  aiEnabled           Boolean @default(false)
  aiGroomPersonality  String?
  aiBridePersonality  String?
  aiSecrets           Json?
  aiMenuInfo          Json?
  aiTransportInfo     Json?
  aiCustomQna         Json?
  aiName            String?
  aiMode            String?   @default("classic")
  aiToneStyle       String?   @default("default")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  galleries       Gallery[]
  rsvps           Rsvp[]
  guestbooks      Guestbook[]
  aiChats         AiChat[]
  reportTokens    ReportToken[]
  reviews         Review[]
}

model AiChat {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  visitorId   String
  role        ChatRole
  content     String
  createdAt   DateTime @default(now())
}

model Gallery {
  id         String    @id @default(cuid())
  weddingId  String
  wedding    Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  mediaUrl   String
  mediaType  MediaType @default(IMAGE)
  order      Int       @default(0)
  caption    String?
  createdAt  DateTime  @default(now())
}

model Rsvp {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  side        Side     @default(GROOM)
  attending   Boolean
  guestCount  Int      @default(1)
  mealCount   Int      @default(0)
  message     String?
  createdAt   DateTime @default(now())
}

model Guestbook {
  id         String   @id @default(cuid())
  weddingId  String
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name       String
  password   String
  message    String
  isHidden   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  type      String   @default("general")
  message   String
  status    InquiryStatus @default(PENDING)
  reply     String?
  repliedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  content   String   @db.Text
  updatedAt DateTime @updatedAt
}

enum Provider {
  EMAIL
  KAKAO
  GOOGLE
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum ChatRole {
  USER
  ASSISTANT
}

enum Theme {
  ROMANTIC_CLASSIC
  MODERN_MINIMAL
  BOHEMIAN_DREAM
  LUXURY_GOLD
  PLAYFUL_POP
  SENIOR_SIMPLE
  FOREST_GARDEN
  OCEAN_BREEZE
}

enum MediaType {
  IMAGE
  VIDEO
}

enum StoryType {
  PHOTO
  VIDEO
}

enum Side {
  GROOM
  BRIDE
}

enum InquiryStatus {
  PENDING
  REPLIED
  CLOSED
}

model ReportToken {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  rating    Int
  content   String?
  source    String   @default("GENERAL")
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Gift {
  id          String    @id @default(cuid())
  code        String    @unique
  packageId   String
  package     Package   @relation(fields: [packageId], references: [id])
  fromUserId  String?
  fromUser    User?     @relation("GiftsSent", fields: [fromUserId], references: [id])
  toEmail     String?
  toUserId    String?
  toUser      User?     @relation("GiftsReceived", fields: [toUserId], references: [id])
  message     String?
  isRedeemed  Boolean   @default(false)
  redeemedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}
